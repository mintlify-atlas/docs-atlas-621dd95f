  "keyFeatures": [
    "4-step checkout flow: product selection, payment & delivery form, summary, result",
    "Secure card tokenization directly with Wompi (card data never reaches the backend)",
    "Real-time transaction status polling until payment resolves (APPROVED / DECLINED / ERROR)",
    "Clean Architecture NestJS backend with DDD modules and Result<T, E> pattern",
    "Redux Toolkit state management with localStorage persistence for checkout progress",
    "Automatic product seeding and PostgreSQL database with TypeORM synchronization",
    "125 unit tests with ~99% code coverage on business logic",
    "Swagger/OpenAPI documentation at /api/docs"
  ],
  "publicApiSurface": [
    "GET /api/products",
    "GET /api/products/:id",
    "GET /api/payments/acceptance-token",
    "POST /api/transactions",
    "GET /api/transactions/:id",
    "GET /api/transactions/:id/status",
    "GET /api/deliveries/transaction/:transactionId"
  ]
}
